rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the requesting user is an admin.
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'tristen_bayley@gailsbread.co.uk';
    }

    // Allow users to read and write their own documents.
    // Allow admin to read all user documents and their subcollections.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Allow admin to read and write the settings collection (e.g. bakery list).
    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }

    // Allow anyone to read the list of shared plans, AND allow logged-in users to create new ones.
    match /sharedPlans/{shareId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.originalUserId;
    }

    // Allow anyone to read a specific plan IF it has 'isShared' set to true.
    match /users/{userId}/plans/{planId} {
      allow read: if resource.data.get('isShared', false) == true;
    }
  }
}
